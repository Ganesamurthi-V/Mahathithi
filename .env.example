# ------------------------------------------------------------------------------
# MAHAATITHI GLOBAL ENVIRONMENT CONFIGURATION
# Copy this file to '.env' before running the start.ps1 script.
# ------------------------------------------------------------------------------

# --- BACKEND (EXPRESS) ---
# Your Supabase PostgreSQL Connection String (Transaction mode / Port 6543 usually recommended for Prisma)
DATABASE_URL="postgres://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Random secret string for JWT authentication (can be anything for local dev)
JWT_SECRET="super_secret_jwt_key_12345"

# Railway / Upstash Redis for Rate Limiting & Auth Lockout
# If left empty, the app will 'fail open' (skip Redis functionality)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- ADMIN PANEL (REACT + VITE) ---
# Port for the Admin panel to run on via Docker
VITE_PORT=5173

# --- MOBILE APP (REACT NATIVE) ---
# Leave this exactly as it is for the script to auto-inject the correct IP.
API_BASE_URL="http://localhost:3000/api"
