// MahaAtithi - Maharashtra Tourism Stakeholder Verification Platform
// Prisma Schema - PostgreSQL

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMERATOR & AUTHENTICATION
// ============================================================================

model Enumerator {
  id            String   @id @default(uuid())
  loginId       String   @unique @map("login_id")
  passwordHash  String   @map("password_hash")
  name          String
  phone         String?
  email         String?
  isActive      Boolean  @default(true) @map("is_active")
  isAdmin       Boolean  @default(false) @map("is_admin")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  districts     EnumeratorDistrict[]
  sessions      Session[]
  surveys       Survey[]
  phoneValidations PhoneValidation[]
  auditLogs     AuditLog[]
  lockedStakeholders Stakeholder[] @relation("LockedBy")

  @@map("enumerators")
}

model District {
  id        String   @id @default(uuid())
  name      String   @unique
  state     String   @default("Maharashtra")
  code      String?  @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  enumerators EnumeratorDistrict[]

  @@map("districts")
}

model EnumeratorDistrict {
  id            String   @id @default(uuid())
  enumeratorId  String   @map("enumerator_id")
  districtId    String   @map("district_id")
  assignedAt    DateTime @default(now()) @map("assigned_at")

  // Relations
  enumerator    Enumerator @relation(fields: [enumeratorId], references: [id], onDelete: Cascade)
  district      District   @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@unique([enumeratorId, districtId])
  @@map("enumerator_districts")
}

model Session {
  id            String   @id @default(uuid())
  enumeratorId  String   @map("enumerator_id")
  refreshToken  String   @unique @map("refresh_token")
  deviceInfo    String?  @map("device_info")
  ipAddress     String?  @map("ip_address")
  isValid       Boolean  @default(true) @map("is_valid")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  // L5 FIX: needed by cleanupSessions.ts to apply a 24h grace period before
  // purging invalidated sessions (filters on when the row was last modified).
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  enumerator    Enumerator @relation(fields: [enumeratorId], references: [id], onDelete: Cascade)

  @@index([enumeratorId])
  @@index([refreshToken])
  @@map("sessions")
}

// ============================================================================
// STAKEHOLDER DATA (Imported from CSV — 313,604 records)
// ============================================================================

enum StakeholderStatus {
  OPEN
  CLOSED
}

model Stakeholder {
  id                       String            @id @default(uuid())
  primaryKeyId             Int               @unique @map("primary_key_id")
  uin                      String?           @map("uin")
  dataSource               String?           @map("data_source")
  cinNumber                String?           @map("cin_number")
  gstNumber                String?           @map("gst_number")
  tinNumber                String?           @map("tin_number")
  companyNameStandardized  String?           @map("company_name_standardized")
  companyNameOriginal      String?           @map("company_name_original")
  fullAddressRaw           String?           @map("full_address_raw")
  addressLine1             String?           @map("address_line_1")
  addressLine2             String?           @map("address_line_2")
  city                     String?           @map("city")
  taluka                   String?           @map("taluka")
  village                  String?           @map("village")
  district                 String?           @map("district")
  state                    String?           @map("state")
  pinCode                  String?           @map("pin_code")
  nicCode                  String?           @map("nic_code")
  nicDescription           String?           @map("nic_description")
  category                 String?           @map("category")
  priorityWeight           Float?            @map("priority_weight")
  companyClass             String?           @map("company_class")
  companyStatus            String?           @map("company_status")
  companyCategory          String?           @map("company_category")
  authorizedCapital        Float?            @map("authorized_capital")
  paidupCapital            Float?            @map("paidup_capital")
  listingStatus            String?           @map("listing_status")
  registrationDate         String?           @map("registration_date")
  fuzzySimilarityScore     Float?            @map("fuzzy_similarity_score")
  crossSourceMatch         String?           @map("cross_source_match")
  humanReviewRequired      String?           @map("human_review_required")
  dedupMatchStatus         String?           @map("dedup_match_status")
  sourceLineageNotes       String?           @map("source_lineage_notes")

  // Location Data
  latitude                 Float?            @map("latitude")
  longitude                Float?            @map("longitude")
  digipin                  String?           @map("digipin")

  // Application-level fields
  status                   StakeholderStatus @default(OPEN) @map("status")
  lockedById               String?           @map("locked_by_id")
  lockedAt                 DateTime?         @map("locked_at")
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")

  // Relations
  lockedBy                 Enumerator?       @relation("LockedBy", fields: [lockedById], references: [id])
  surveys                  Survey[]
  phoneValidations         PhoneValidation[]

  // === SEARCH INDEXES ===
  // B-tree indexes for exact and range queries
  @@index([district])
  @@index([state])
  @@index([pinCode])
  @@index([category])
  @@index([nicCode])
  @@index([gstNumber])
  @@index([status])
  @@index([companyStatus])
  @@index([lockedById])

  // Composite indexes for common filter combinations
  @@index([district, category])
  @@index([state, category])
  @@index([district, pinCode])
  @@index([district, status])
  @@index([state, district])
  @@index([companyNameStandardized, district])

  // PERF: taluka/city are queried by the stakeholder search filters but were
  // unindexed, forcing full scans on the 313K-row table.
  @@index([taluka])
  @@index([city])
  // PERF: dashboard "open in my district" counts filter on (status, district);
  // and sync getChanges filters stakeholders by updatedAt > since.
  @@index([status, district])
  @@index([updatedAt])
  // PERF: the default list + search order by priorityWeight desc, name asc.
  // Without this the DB sorts the whole filtered set on every request.
  // (Trigram GIN indexes for ILIKE search are added via raw SQL migration
  // 20250724_perf_indexes since Prisma can't express gin_trgm_ops natively.)
  @@index([priorityWeight])
  @@index([district, priorityWeight])

  @@map("stakeholders")
}

// ============================================================================
// SURVEY DATA (Collected by enumerators)
// ============================================================================

model Survey {
  id              String   @id @default(uuid())
  stakeholderId   String   @map("stakeholder_id")
  enumeratorId    String   @map("enumerator_id")

  // Contact Information (editable by enumerator)
  contactPerson   String?  @map("contact_person")
  designation     String?  @map("designation")
  mobileNumber    String?  @map("mobile_number")
  email           String?  @map("email")
  
  // Secondary Contact Information (Optional)
  contactPerson2  String?  @map("contact_person_2")
  mobileNumber2   String?  @map("mobile_number_2")
  email2          String?  @map("email_2")

  website         String?  @map("website")
  businessCategory String? @map("business_category")
  notes           String?  @map("notes")

  // Survey-specific fields
  gstNumber       String?  @map("gst_number")
  organizationType String? @map("organization_type")
  remarks         String?  @map("remarks")

  // GPS Data (from actual device)
  latitude        Float?   @map("latitude")
  longitude       Float?   @map("longitude")
  gpsAccuracy     Float?   @map("gps_accuracy")
  digipin         String?  @map("digipin")

  nearestPoliceStation    String?  @map("nearest_police_station")
  nearestHealthcareCenter String?  @map("nearest_healthcare_center")

  // ─── Step 1: Category & Type ───────────────────────────────────────────────
  subCategories             String[]  @map("sub_categories")

  // ─── Step 2: Basic Information ─────────────────────────────────────────────
  businessName              String?   @map("business_name")
  ownerName                 String?   @map("owner_name")
  district                  String?   @map("district")
  city                      String?   @map("city")
  taluka                    String?   @map("taluka")
  village                   String?   @map("village")
  pinCode                   String?   @map("pin_code")
  businessAddress           String?   @map("business_address")
  workingAddress            String?   @map("working_address")
  maleEmployees             Int?      @map("male_employees")
  femaleEmployees           Int?      @map("female_employees")
  landline                  String?   @map("landline")
  alternateMobile           String?   @map("alternate_mobile")
  alternateEmail            String?   @map("alternate_email")
  aadharNumber              String?   @map("aadhar_number")       // AES-256-GCM encrypted
  udyamAadharRegNo          String?   @map("udyam_aadhar_reg_no")
  fssaiNumber               String?   @map("fssai_number")

  // ─── Step 4: Details ───────────────────────────────────────────────────────
  description               String?   @map("description")
  accommodationFacilities   Json?     @map("accommodation_facilities")
  accommodationPolicies     String?   @map("accommodation_policies")
  workingHours              Json?     @map("working_hours")
  faq                       Json?     @map("faq")

  // ─── Step 5: Rooms & Pricing (Accommodations only) ─────────────────────────
  rooms                     Json?     @map("rooms")
  couponCodes               Json?     @map("coupon_codes")
  saleOff                   Float?    @map("sale_off")
  additionalServiceFees     Json?     @map("additional_service_fees")
  bookingNote               String?   @map("booking_note")

  // ─── Step 6: Your Socials ──────────────────────────────────────────────────
  socialLinks               Json?     @map("social_links")

  // ─── Step 7: Business Documents ────────────────────────────────────────────
  aboutBusiness             String?   @map("about_business")
  registeredTravelForLife   Boolean   @default(false) @map("registered_travel_for_life")
  registeredGreenLeaf       Boolean   @default(false) @map("registered_green_leaf")
  receivedTourismAward      Boolean   @default(false) @map("received_tourism_award")
  customDocuments           Json?     @map("custom_documents")

  // ─── Step 8: Terms & Conditions ────────────────────────────────────────────
  agreedToTerms             Boolean   @default(false) @map("agreed_to_terms")
  declaredInfoCorrect       Boolean   @default(false) @map("declared_info_correct")
  acknowledgedDotLiability  Boolean   @default(false) @map("acknowledged_dot_liability")

  // Status & Sync
  isDraft         Boolean  @default(true) @map("is_draft")
  isCompleted     Boolean  @default(false) @map("is_completed")
  isSynced        Boolean  @default(false) @map("is_synced")
  localId         String?  @map("local_id") // SQLite local ID for sync mapping
  completedAt     DateTime? @map("completed_at")
  syncedAt        DateTime? @map("synced_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  stakeholder     Stakeholder @relation(fields: [stakeholderId], references: [id])
  enumerator      Enumerator  @relation(fields: [enumeratorId], references: [id])
  media           Media[]

  @@unique([stakeholderId, enumeratorId])
  @@index([stakeholderId])
  @@index([enumeratorId])
  @@index([isCompleted])
  @@index([isSynced])
  @@map("surveys")
}

// ============================================================================
// MEDIA (Photos & Videos)
// ============================================================================

enum MediaType {
  PHOTO
  VIDEO
}

enum PhotoCategory {
  BUILDING_FRONT
  SIGNBOARD
  INTERIOR
  STAKEHOLDER
  ADDITIONAL
  DISPLAY_IMAGE
  HEADER_SLIDER
  UDYOG_AADHAR_DOC
  AADHAR_CARD_DOC
  PAN_CARD_DOC
  CANCELLED_CHEQUE_DOC
  CUSTOM_DOC
}

model Media {
  id              String        @id @default(uuid())
  surveyId        String        @map("survey_id")
  type            MediaType     @map("type")
  photoCategory   PhotoCategory? @map("photo_category")

  // Storage
  filePath        String        @map("file_path")  // S3 key
  fileUrl         String?       @map("file_url")   // S3 presigned URL
  fileName        String        @map("file_name")
  fileSize        Int?          @map("file_size")   // bytes
  mimeType        String?       @map("mime_type")

  // Metadata
  latitude        Float?        @map("latitude")
  longitude       Float?        @map("longitude")
  gpsAccuracy     Float?        @map("gps_accuracy")
  digipin         String?       @map("digipin")
  capturedAt      DateTime      @map("captured_at")
  duration        Int?          @map("duration")    // seconds, for video
  thumbnailPath   String?       @map("thumbnail_path") // for video

  // Sync
  isSynced        Boolean       @default(false) @map("is_synced")
  localId         String?       @map("local_id")
  syncedAt        DateTime?     @map("synced_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  // L6/N2 FIX: soft-delete tombstone. media.delete marks this before removing the
  // S3 object so a failed S3 delete leaves a row a cleanup job can retry, and so
  // queries never reference a file that is already gone. Excluded from getBySurvey.
  deletedAt       DateTime?     @map("deleted_at")

  // Relations
  survey          Survey        @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
  @@index([type])
  @@index([deletedAt])
  @@map("media")
}

// ============================================================================
// PHONE VALIDATION
// ============================================================================

enum VerificationStatus {
  PENDING_VERIFICATION
  VERIFIED
  FAILED
}

model PhoneValidation {
  id              String             @id @default(uuid())
  stakeholderId   String             @map("stakeholder_id")
  enumeratorId    String             @map("enumerator_id")
  phoneNumber     String             @map("phone_number")
  status          VerificationStatus @default(PENDING_VERIFICATION) @map("status")
  method          String             @default("phone_call") @map("method")
  verifiedAt      DateTime?          @map("verified_at")
  remarks         String?            @map("remarks")

  // Sync
  isSynced        Boolean            @default(false) @map("is_synced")
  localId         String?            @map("local_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  // Relations
  stakeholder     Stakeholder        @relation(fields: [stakeholderId], references: [id])
  enumerator      Enumerator         @relation(fields: [enumeratorId], references: [id])

  @@index([stakeholderId])
  @@index([enumeratorId])
  @@map("phone_validations")
}

// ============================================================================
// SYNC QUEUE
// ============================================================================

enum SyncStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum SyncAction {
  CREATE
  UPDATE
  DELETE
  UPLOAD_MEDIA
}

model SyncQueue {
  id           String     @id @default(uuid())
  // N1/M4 FIX: column the dashboard's per-enumerator sync filter relies on.
  // Without it, prisma.syncQueue.count({ where: { enumeratorId } }) throws and
  // GET /dashboard/stats 500s for every non-admin user.
  enumeratorId String?    @map("enumerator_id")
  entityType   String     @map("entity_type")    // survey, media, phone_validation
  entityId     String     @map("entity_id")
  action       SyncAction @map("action")
  payload      Json?      @map("payload")
  status       SyncStatus @default(PENDING) @map("status")
  retryCount   Int        @default(0) @map("retry_count")
  maxRetries   Int        @default(5) @map("max_retries")
  errorMessage String?    @map("error_message")
  processedAt  DateTime?  @map("processed_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([status])
  @@index([entityType, entityId])
  @@index([enumeratorId])
  // PERF: dashboard pending/failed counts filter on (enumeratorId, status).
  @@index([status, enumeratorId])
  @@map("sync_queue")
}

// ============================================================================
// AUDIT LOGS
// ============================================================================

model AuditLog {
  id            String   @id @default(uuid())
  action        String   @map("action")           // login, survey_created, stakeholder_locked, etc.
  entityType    String?  @map("entity_type")
  entityId      String?  @map("entity_id")
  enumeratorId  String?  @map("enumerator_id")
  details       Json?    @map("details")
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  enumerator    Enumerator? @relation(fields: [enumeratorId], references: [id])

  @@index([enumeratorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// FACILITY (For offline sync)
// ============================================================================

model Facility {
  id        String   @id @default(uuid())
  name      String
  type      String   // 'POLICE_STATION' | 'HEALTHCARE'
  district  String?
  state     String?
  latitude  Float
  longitude Float
  digipin   String?
  
  @@index([type])
  @@index([district])
  @@index([state])
  @@index([name])
  @@map("facilities")
}
