# MahaAtithi Backend — Environment Variables
# ============================================================
# Copy this file to .env (never commit .env to git):
#   cp .env.example .env
#
# ❗ Variables marked [REQUIRED] will cause the server to crash at startup if
#    not set (enforced by requireEnv() in config/index.ts). They must be real
#    values — not placeholders. The JWT_SECRET must be ≥ 32 characters.
#
# To generate a strong JWT_SECRET:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ============================================================

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database [REQUIRED] ─────────────────────────────────────
DATABASE_URL="postgresql://mahaatithi_admin:CHANGE_ME@localhost:5432/mahaatithi?schema=public"

# ─── JWT [REQUIRED — min 32 characters] ─────────────────────
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_FROM_CRYPTO_RANDOMBYTES_48
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Docker / Local Postgres [REQUIRED if using docker-compose] ──
POSTGRES_PASSWORD=CHANGE_ME

# ─── Upstash Redis REST [REQUIRED] ──────────────────────────────
# Used for per-account brute-force lockout. Create a free database at
# https://upstash.com and copy the REST URL and token here.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=CHANGE_ME_UPSTASH_TOKEN

# ─── AWS S3 ──────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=mahaatithi-media
# Uncomment for local MinIO / S3-compatible store:
# S3_ENDPOINT=http://localhost:9000

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5

# ─── Misc ────────────────────────────────────────────────────
CSV_BATCH_SIZE=1000
LOG_LEVEL=info

